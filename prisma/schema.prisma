// schema.prisma is the source of truth for table shapes. Row Level Security
// policies, the is_workspace_member() helper, and Storage bucket policies
// cannot be expressed here  they live as raw SQL appended to
// prisma/migrations/0001_init/migration.sql. Never let the two drift: any
// model change here needs a matching RLS review in that migration.
//
// IMPORTANT: Prisma Client connects via DATABASE_URL, a direct Postgres
// connection with no Supabase session  it does NOT run as auth.uid() and is
// NOT subject to RLS the way supabase-js is. Use Prisma Client only for
// trusted/server-side operations (equivalent trust level to
// lib/supabase/admin.ts). User-facing reads/writes that must be scoped to the
// signed-in user still go through lib/supabase/server.ts so RLS applies.

generator client {
  provider = "prisma-client-js"
}

// Connection URLs live in prisma.config.ts (Prisma 7 no longer reads them
// from the schema file) and in lib/prisma.ts for the runtime client.
datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  owner
  editor
  viewer

  @@map("workspace_role")
}

// Three protection tiers for an EnvFile, from least to most restrictive.
// none: anyone with workspace access reads it directly. password_2fa:
// today's existing gate (password + TOTP/passkey). password_2fa_key adds a
// third factor  the workspace-issued Access Key on WorkspaceMember  on top
// of password_2fa, see lib/env-lock.ts's key-step token.
enum ProtectionLevel {
  none
  password_2fa
  password_2fa_key

  @@map("protection_level")
}

// email: a specific person is invited by address (single-use, consumed on
// accept). link: a shareable join link anyone with it can use until it's
// revoked or expires (multi-use).
enum InvitationKind {
  email
  link

  @@map("invitation_kind")
}

model Workspace {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  // Free-text, purely descriptive -- shown on the settings page, no other behavior depends on it.
  description String?
  // Path in the "workspace-logos" Storage bucket, not a public URL (mirrors Profile.avatarPath).
  logoPath    String?  @map("logo_path")
  ownerId     String   @map("owner_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  // Stripe pay-as-you-go billing (see lib/stripe.ts, lib/env-billing.ts). One
  // subscription per workspace, quantity = paid environments beyond the free
  // FREE_ENVIRONMENT_LIMIT. Written only by Prisma (webhook/server actions) --
  // write-locked against the "authenticated" role by a DB trigger, same
  // pattern as Profile.isPremium, so an owner can't self-grant status via a
  // direct supabase-js call.
  stripeCustomerId         String? @map("stripe_customer_id")
  stripeSubscriptionId     String? @map("stripe_subscription_id")
  // "active" | "past_due" | "canceled" | null (no subscription yet). Mirrors
  // Stripe's own subscription.status values so the webhook can write it
  // through unchanged.
  stripeSubscriptionStatus String? @map("stripe_subscription_status")

  members      WorkspaceMember[]
  envFiles     EnvFile[]
  invitations  Invitation[]
  integrations IntegrationConnection[]

  @@index([ownerId])
  @@index([stripeCustomerId])
  @@map("workspaces")
}

model WorkspaceMember {
  workspaceId        String        @map("workspace_id") @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  role               WorkspaceRole @default(viewer)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  // scrypt hash ("salt:hash" hex, same format as EnvFile.passwordHash) of this
  // member's workspace-issued Access Key ("Klucz Zabezpieczeń"), the third
  // factor required by ProtectionLevel.password_2fa_key. Null until the owner
  // generates one. The raw key is shown to the owner exactly once (on
  // generate/regenerate) and never stored  if a member loses it, only the
  // owner can issue a new one (see regenerateAccessKeyAction).
  accessKeyHash      String?       @map("access_key_hash")
  accessKeyUpdatedAt DateTime?     @map("access_key_updated_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model EnvFile {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String          @map("workspace_id") @db.Uuid
  name            String
  storagePath     String          @map("storage_path") // path in the "env-files" Storage bucket
  createdBy       String?         @map("created_by") @db.Uuid // nullable: ON DELETE SET NULL when the creator's account is removed
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  // scrypt hash ("salt:hash" hex) of the environment's reveal password, null
  // when unprotected. Never the plaintext. Presence of a hash means a member
  // must pass password + 2FA (see WebauthnCredential/TotpCredential) before
  // the app returns decoded pairs  see lib/env-lock.ts.
  passwordHash    String?         @map("password_hash")
  // Tier this file is protected at (see ProtectionLevel). password_2fa and
  // password_2fa_key both require passwordHash to be set; password_2fa_key
  // additionally requires the reader's WorkspaceMember.accessKeyHash.
  protectionLevel ProtectionLevel @default(none) @map("protection_level")
  // Optional linked GitHub repo (owner/name), shown as a commit scaffold in
  // the creator/detail sidebar. Each viewer fetches commits with their own
  // connected GitHub token (GithubConnection)  linking a repo here doesn't
  // grant anyone access to it beyond what their own GitHub account already has.
  githubOwner     String?         @map("github_owner")
  githubRepo      String?         @map("github_repo")
  // Free-text notes and an optional linked website URL, purely descriptive.
  description     String?
  websiteUrl      String?         @map("website_url")
  // Provider -> chosen sync target, e.g. {"vercel": {"id":"prj_123","name":"my-app"}}.
  // Json instead of a join table since it's only ever read/written whole, per
  // env file, never queried across rows  see lib/integrations/sync.ts.
  syncTargets     Json?           @map("sync_targets")

  workspace  Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  shareLinks ShareLink[]
  hiddenFor  EnvFileHiddenMember[]

  @@index([workspaceId, createdAt])
  @@map("env_files")
}

// Per-member visibility exceptions: absence of a row means visible (the
// default), a row means this env file is hidden from this member. Owners are
// never subject to this  see is_workspace_member('owner') bypass in the
// env_files/Storage RLS policies.
model EnvFileHiddenMember {
  envFileId   String   @map("env_file_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  envFile EnvFile @relation(fields: [envFileId], references: [id], onDelete: Cascade)

  @@id([envFileId, userId])
  @@index([workspaceId, userId])
  @@map("env_file_hidden_members")
}

// A pending or resolved invite to join a workspace. kind = email is
// single-use (acceptedAt is set on accept, then it's dead); kind = link is
// reusable by anyone holding the token until revoked/expired.
model Invitation {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String         @map("workspace_id") @db.Uuid
  kind        InvitationKind
  email       String? // required for kind=email, null for kind=link
  role        WorkspaceRole  @default(viewer)
  // SHA-256 hex digest of the raw invite token (lib/tokens.ts hashToken()),
  // same pattern as ShareLink.tokenHash  the raw token is never stored.
  tokenHash   String         @unique @map("token_hash")
  expiresAt   DateTime       @map("expires_at") @db.Timestamptz
  revoked     Boolean        @default(false)
  acceptedAt  DateTime?      @map("accepted_at") @db.Timestamptz
  invitedBy   String?        @map("invited_by") @db.Uuid // nullable: ON DELETE SET NULL when the inviter's account is removed
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@map("invitations")
}

// Profile is 1:1 with auth.users (id is the Supabase auth user id, not a
// separate identity)  every signed-in user gets exactly one row, created
// lazily on first visit to /profile via lib/profile.ts.
model Profile {
  userId                 String   @id @map("user_id") @db.Uuid
  displayName            String?  @map("display_name")
  bio                    String?
  avatarPath             String?  @map("avatar_path") // path in the "avatars" Storage bucket, not a public URL
  marketingConsent       Boolean  @default(false) @map("marketing_consent")
  productEmailsConsent   Boolean  @default(true) @map("product_emails_consent")
  // ponytail: manual flag, no billing/Stripe wired yet. Flip by hand until a
  // real subscription flow exists to set it.
  isPremium              Boolean  @default(false) @map("is_premium")
  // Onboarding analytics, asked once on the onboarding form and never shown
  // again (see components/onboarding-form.tsx). All nullable -- older rows
  // and anyone who skips predate/skip these questions. Free-text values are
  // never accepted; the form only ever sends one of a fixed set of option
  // ids (see lib/onboarding-survey.ts), so no CHECK constraint is needed.
  referralSource         String?  @map("referral_source")
  accountType            String?  @map("account_type")
  companySize            String?  @map("company_size")
  // Integration slugs (from lib/integrations.ts's static catalog) the user has
  // asked to be notified about. No OAuth is wired up yet  see IntegrationsSearch.
  interestedIntegrations String[] @default([]) @map("interested_integrations")
  // Kept in sync by the profiles_set_updated_at DB trigger, not Prisma's
  // client-side @updatedAt  every write to this table goes through
  // supabase-js, not Prisma Client, so the trigger is the only thing that
  // actually runs on every insert/update.
  updatedAt              DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("profiles")
}

// One TOTP enrollment per user, account-wide (not tied to a workspace or
// environment)  used as one of the two selectable 2FA methods when
// unlocking a password-protected environment (see lib/totp.ts). The secret
// is AES-256-GCM encrypted at rest with a server-only key (lib/totp-crypto.ts)
// since, unlike other row data, this is a standing bearer credential.
model TotpCredential {
  userId    String   @id @map("user_id") @db.Uuid
  secretEnc String   @map("secret_enc") // base64 ciphertext
  secretIv  String   @map("secret_iv") // base64 96-bit GCM nonce
  secretTag String   @map("secret_tag") // base64 GCM auth tag
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("totp_credentials")
}

// WebAuthn passkeys/platform authenticators (Windows Hello, Touch ID, etc.)
// enrolled by a user  a user may register several. The other selectable
// 2FA method for unlocking a password-protected environment (lib/webauthn.ts).
// Public keys aren't secret, so no app-level encryption is needed here
// (unlike TotpCredential).
model WebauthnCredential {
  id          String   @id @map("credential_id") // base64url WebAuthn credential ID
  userId      String   @map("user_id") @db.Uuid
  publicKey   String   @map("public_key") // base64-encoded COSE public key bytes
  counter     Int      @default(0) // replay-protection counter, bumped on every successful auth
  transports  String[] @default([])
  deviceLabel String?  @map("device_label")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@map("webauthn_credentials")
}

// One GitHub OAuth connection per user, account-wide (not tied to a
// workspace or environment)  linking a repo to an environment (EnvFile.githubOwner/githubRepo)
// just remembers which repo, it does not copy access: every viewer fetches
// commits with their own token, so GitHub's own repo permissions still apply.
model GithubConnection {
  userId          String   @id @map("user_id") @db.Uuid
  githubUserId    Int      @map("github_user_id")
  githubLogin     String   @map("github_login")
  githubAvatarUrl String?  @map("github_avatar_url")
  // AES-256-GCM ciphertext (lib/totp-crypto.ts's encryptSecret)  never the
  // raw access token, same trust level as TotpCredential's secret.
  accessTokenEnc  String   @map("access_token_enc")
  accessTokenIv   String   @map("access_token_iv")
  accessTokenTag  String   @map("access_token_tag")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("github_connections")
}

// One row per `envshare login` device-code round trip (see lib/cli-auth.ts).
// Short-lived (10 min) and single-use  the raw device code and, once
// approved, the raw CLI token are held here only long enough for the CLI's
// poll to pick them up, then the row is deleted.
model CliDeviceAuth {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceCodeHash String    @unique @map("device_code_hash")
  // Short human-typeable code shown to the user on the authorize page to
  // confirm they're approving the CLI instance that's actually polling.
  userCode       String    @unique @map("user_code")
  status         String    @default("pending") // pending | approved | denied
  userId         String?   @map("user_id") @db.Uuid
  // Set once approved; cleared (and the raw value handed to the CLI) the
  // moment /api/cli/device/poll picks it up, so it's never left sitting here.
  issuedToken    String?   @map("issued_token")
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("cli_device_auths")
}

// A long-lived bearer credential for the `envshare` CLI, scoped to one user.
// Same trust level as a Supabase session cookie  every CLI API route
// resolves this to a userId and then re-applies the same membership/role
// checks Server Actions already do (see lib/cli-auth.ts).
model CliToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  userId     String    @map("user_id") @db.Uuid
  label      String? // e.g. hostname, shown in a future "manage CLI sessions" UI
  revoked    Boolean   @default(false)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@map("cli_tokens")
}

// One connection per (workspace, provider)  owner-only to create/remove,
// shared by the whole team once set up (unlike GithubConnection, which is
// per-user). credential holds a provider-specific JSON payload (OAuth token,
// PAT, webhook URL, ids)  one AES-256-GCM blob (lib/totp-crypto.ts's
// encryptSecret) instead of a column per provider, since nothing ever queries
// into it. See lib/integration-connection.ts.
model IntegrationConnection {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  provider      String // "github-actions" | "gitlab" | "vercel" | "netlify" | "slack" | "discord"
  label         String? // e.g. GitHub login / GitLab host / webhook channel name, for display only
  credentialEnc String   @map("credential_enc")
  credentialIv  String   @map("credential_iv")
  credentialTag String   @map("credential_tag")
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@map("integration_connections")
}

// Audit trail for a sync push  intentionally holds no secret values, only
// who pushed what to where and whether it succeeded (see security review:
// pushing secrets off-platform must always be traceable).
model IntegrationSyncLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  envFileId    String   @map("env_file_id") @db.Uuid
  provider     String
  targetName   String   @map("target_name")
  status       String // "success" | "error"
  errorMessage String?  @map("error_message")
  triggeredBy  String?  @map("triggered_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([workspaceId, createdAt])
  @@map("integration_sync_logs")
}

model ShareLink {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  envFileId String   @map("env_file_id") @db.Uuid
  // SHA-256 hex digest of the raw token from lib/tokens.ts (hashToken()), never
  // the raw value. The app hashes the raw token from the link and compares
  // against this column when resolving a share link; the raw token is never
  // stored.
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  revoked   Boolean  @default(false)
  createdBy String?  @map("created_by") @db.Uuid // nullable: ON DELETE SET NULL when the creator's account is removed
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  envFile EnvFile @relation(fields: [envFileId], references: [id], onDelete: Cascade)

  @@index([envFileId])
  @@map("share_links")
}
